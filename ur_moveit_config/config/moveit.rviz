Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded: ~
      Splitter Ratio: 0.5
    Tree Height: 312
  - Class: rviz_common/Help
    Name: Help
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: moveit_task_constructor/Motion Planning Tasks
    Global Settings:
      Task View Settings:
        Old task handling: Keep
        Show Computation Times: true
        Task Expansion: All Expanded
    Name: Motion Planning Tasks
    Tasks View:
      property_splitter:
        - 406
        - 135
      solution_sorting:
        column: 0
        order: 1
      solutions_splitter:
        - 273
        - 137
      solutions_view_columns: ~
      tasks_view_columns:
        - 188
        - 23
        - 23
        - 37
